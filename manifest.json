{
  "name": "Mudbrick — Free PDF Editor",
  "short_name": "Mudbrick",
  "description": "Free, open-source PDF editor that runs entirely in your browser. Annotate, merge, split, fill forms, sign, redact, OCR — no subscription, no uploads, no server.",
  "start_url": "/",
  "display": "standalone",
  "theme_color": "#c0392b",
  "background_color": "#f5f5f5",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": { "application/pdf": [".pdf"] }
    }
  ],
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "pdf", "accept": ["application/pdf", ".pdf"] }]
    }
  },
  "screenshots": [],
  "shortcuts": [
    { "name": "Open PDF", "short_name": "Open", "url": "/" },
    { "name": "Merge PDFs", "short_name": "Merge", "url": "/?action=merge" }
  ]
}
